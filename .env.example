# Copie ce fichier en .env et remplis les valeurs.
# .env est gitignoré, ces secrets ne partent JAMAIS sur GitHub.

# France Travail (ex-Pôle Emploi) — https://francetravail.io/
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Adzuna — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble — https://jooble.org/api/about
JOOBLE_API_KEY=

# Telegram bot — voir README pour la configuration via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
